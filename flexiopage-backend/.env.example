# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/flexiopage

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES=7d

# Google OAuth — Web Application Client ID from
# https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must list every frontend host (dev + prod).
# Leave empty to disable Google sign-in; /api/auth/google then returns 500.
GOOGLE_CLIENT_ID=

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000

# File storage: local | s3
STORAGE_DRIVER=local
UPLOAD_PATH=./uploads
PUBLIC_URL_PREFIX=/uploads

# S3 (optional, when STORAGE_DRIVER=s3)
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI – for AI landing page generation (optional; fallback to templates if not set)
# OPENAI_API_KEY=sk-...

# fal.ai – AI landing page generation (LLM + FLUX images). Format: <key_id>:<key_secret>
# FAL_KEY=...

# LLM model used by fal any-llm (defaults to anthropic/claude-sonnet-4.5 — best for dialect copy)
# Note: fal uses dots in model versions (claude-3.5-sonnet), not dashes.
# FAL_LLM_MODEL=anthropic/claude-sonnet-4.5
# Alternatives (cheaper / faster):
# FAL_LLM_MODEL=anthropic/claude-3.5-sonnet
# FAL_LLM_MODEL=anthropic/claude-haiku-4.5
# FAL_LLM_MODEL=openai/gpt-4o
# FAL_LLM_MODEL=google/gemini-2.5-pro
# FAL_LLM_MODEL=google/gemini-flash-1.5

# Image model for hero / gallery / product. Default = Google Nano Banana
# (gemini-2.5-flash-image) — best at prompt following and clean lifestyle photos.
# FAL_IMAGE_MODEL=fal-ai/nano-banana
# Alternatives:
# FAL_IMAGE_MODEL=fal-ai/flux/schnell      # ultra-cheap FLUX
# FAL_IMAGE_MODEL=fal-ai/flux/dev          # higher quality FLUX
# FAL_IMAGE_MODEL=fal-ai/flux-pro/v1.1     # premium FLUX

# Override for testimonial avatar generation (defaults to FAL_IMAGE_MODEL).
# FAL_AVATAR_MODEL=fal-ai/nano-banana
# FAL_AVATAR_MODEL=fal-ai/flux-realism     # use this for ultra-photoreal humans

# Set to "false" to skip image generation entirely (text-only pages)
# LANDING_AI_IMAGES_ENABLED=true

# Email — Resend (free tier 3k/month). If unset, emails are logged to console.
# Get your API key at https://resend.com/api-keys
# RESEND_API_KEY=re_...
# Default sender. For prod, use a verified domain (set up in Resend dashboard).
# Tant que le domaine n'est pas vérifié, garde `onboarding@resend.dev`.
# EMAIL_FROM=FlexioPage <noreply@yourdomain.com>
# Adresse vers laquelle rediriger les réponses des vendeurs (replyTo).
# Le sous-domaine `mail.flexiopage.com` n'a pas de MX entrant, donc sans
# replyTo les réponses se perdent. Défaut: support@flexiopage.com.
# SUPPORT_EMAIL=support@flexiopage.com
# Utilisés par les mails transactionnels :
#  - Confirmation d'email au signup     (sendVerificationEmail)
#  - Reçu de commande digital paid      (sendOrderPaidEmail)
# Le lien dans chaque mail pointe vers FRONTEND_URL — vérifie qu'il est correct
# en prod (ex: https://app.flexiopage.com), sinon les liens redirigent ailleurs.

# CinetPay (mobile money: Wave, Orange Money, MTN MoMo, Moov + Visa cards).
# Sign up at https://cinetpay.com — free for sellers, ~1-2% fee per transaction.
# Without these keys, a Mock provider lets you test the flow locally.
# CINETPAY_API_KEY=
# CINETPAY_SITE_ID=
# CINETPAY_SECRET_KEY=          # enables `x-token` HMAC verification of webhooks
# CINETPAY_NOTIFY_URL=          # defaults to API_PUBLIC_URL/api/webhooks/cinetpay
# API_PUBLIC_URL=https://api.yourdomain.com

# Flutterwave (Card + Mobile Money: Nigeria, Ghana, Kenya, South Africa…).
# Sign up at https://flutterwave.com → Settings → API. Use TEST keys for sandbox.
# Without these keys, the Mock provider takes over for local testing.
# FLW_PUBLIC_KEY=FLWPUBK_TEST-...
# FLW_SECRET_KEY=FLWSECK_TEST-...
# FLW_SECRET_HASH=               # the "Secret hash" you set in FLW dashboard → Webhooks
#                                # inbound webhooks must echo it in the `verif-hash` header
# Webhook URL to register in the Flutterwave dashboard:
#   {API_PUBLIC_URL}/api/webhooks/flutterwave

# MogaDelivery — receives every paid order via the order.created webhook.
# Shared secret (must match the value configured on the MogaDelivery side).
# Generate: openssl rand -hex 32
# FLEXIOPAGE_WEBHOOK_SECRET=
# Override the default endpoint if MogaDelivery moves it.
# MOGADELIVERY_WEBHOOK_URL=https://api.admin-mogadelivery.com/api/webhooks/flexiopage

# ── Messenger Bot module (src/modules/messenger-bot) ──────────────────
# Anthropic Claude — darija/ar/fr conversational agent + tool use.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL_PRIMARY=claude-haiku-4-5-20251001
# CLAUDE_MODEL_FALLBACK=claude-sonnet-4-5

# Facebook / Messenger (Meta App → Messenger product).
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# MESSENGER_VERIFY_TOKEN=flexiopage_bot_verify_2026   # any string; must match the value set in the Meta webhook config
# FACEBOOK_REDIRECT_URI=http://localhost:5050/api/messenger-bot/facebook/callback
# FACEBOOK_GRAPH_VERSION=v19.0

# Redis — BullMQ queue for async message processing.
# REDIS_URL=redis://localhost:6379

# AES-256 key used to encrypt Facebook page access tokens at rest.
# MUST be 32 bytes. Generate: openssl rand -hex 32  (→ 64 hex chars)
# TOKEN_ENCRYPTION_KEY=

# ── Storefront ISR revalidation ────────────────────────────────────────
# After product/store/page/collection writes, the backend pings the
# Next.js frontend to drop its cached HTML (otherwise sellers wait up
# to 60s — the ISR window — to see their edits live). Both vars must
# match the values on the frontend; if either is unset, the ping is a
# silent no-op (cache simply stays until the natural ISR refresh).
# FRONTEND_REVALIDATE_URL=http://localhost:3002/api/revalidate
# REVALIDATE_SECRET=          # openssl rand -hex 32

# ── Cloudinary (alternative storage driver) ────────────────────────────
# Free tier : 25 GB stockage + 25 GB bande passante/mois, CDN inclus.
# Console : https://console.cloudinary.com → Dashboard pour les 3 valeurs.
# STORAGE_DRIVER=cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
