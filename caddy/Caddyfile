# FlexioPage — Caddy reverse proxy with auto-TLS.
#
# All certs are issued via Let's Encrypt HTTP-01 challenge — no DNS API
# tokens required, works with the stock `caddy:2-alpine` image.
#
# Three traffic patterns:
#
#   1. Platform apex + www (flexiopage.com, www.flexiopage.com)
#      → standard cert at boot, proxied to Next.js on :3000.
#
#   2. Backend API (api.flexiopage.com)
#      → standard cert at boot, proxied to Express on :5000.
#
#   3. Everything else hitting :443 (vendor subdomains like
#      macaftans.flexiopage.com AND seller custom domains like
#      afrochance.com)
#      → on-demand TLS: Caddy issues a cert the FIRST time a real visitor
#        lands on the host, only after the backend's /internal/cert-ask
#        endpoint approves it. Backend approves PLATFORM_APEX +
#        *.PLATFORM_APEX automatically, and any Store with
#        customDomainVerified=true.
#      → proxied to Next.js on :3000 with the Host header preserved so
#        middleware can resolve the right store.
#
# Required env (passed through docker-compose):
#   PLATFORM_APEX           — bare apex of the platform (e.g. flexiopage.com)
#   CADDY_ADMIN_EMAIL       — contact for Let's Encrypt registration

{
	email {$CADDY_ADMIN_EMAIL}

	# Gate on-demand TLS issuance. Caddy GETs this URL with ?domain=<host>
	# before requesting a cert. 2xx = proceed, anything else = refuse.
	# Backend is reachable inside the compose network as http://backend:5000.
	on_demand_tls {
		ask http://backend:5000/internal/cert-ask
	}
}

# ────────────────────────────────────────────────────────────────────
# Platform apex + www — standard cert.
# ────────────────────────────────────────────────────────────────────
{$PLATFORM_APEX:flexiopage.com}, www.{$PLATFORM_APEX:flexiopage.com} {
	encode zstd gzip
	request_body {
		max_size 30MB
	}

	reverse_proxy frontend:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		transport http {
			read_timeout 600s
			write_timeout 600s
		}
	}
}

# ────────────────────────────────────────────────────────────────────
# Backend API — single host, standard cert.
# ────────────────────────────────────────────────────────────────────
api.{$PLATFORM_APEX:flexiopage.com} {
	encode zstd gzip
	request_body {
		max_size 30MB
	}

	reverse_proxy backend:5000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		transport http {
			read_timeout 600s
			write_timeout 600s
		}
	}
}

# ────────────────────────────────────────────────────────────────────
# Catch-all on :443 — handles every other host:
#   - vendor subdomains (*.flexiopage.com): cert issued on demand, gate
#     approves because cert-ask returns 200 for "kind: platform".
#   - seller custom domains: cert issued on demand, gate approves only
#     when the Store is customDomainVerified.
#
# Same upstream as the platform frontend — Next middleware reads the
# Host header to pick the right store, so it must reach the app intact.
# ────────────────────────────────────────────────────────────────────
:443 {
	tls {
		on_demand
	}

	encode zstd gzip
	request_body {
		max_size 30MB
	}

	reverse_proxy frontend:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		transport http {
			read_timeout 600s
			write_timeout 600s
		}
	}
}
