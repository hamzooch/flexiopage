{
  "name": "flexiopage-desktop",
  "version": "1.0.0",
  "description": "Flexiopage Desktop Application",
  "main": "src/main/main.ts",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm run frontend-dev\" \"npm run electron-dev\"",
    "electron-dev": "cross-env NODE_ENV=development wait-on http://localhost:3002 && tsc && electron dist/main/main.js",
    "frontend-dev": "cd ../flexiopage-frontend && npm run dev",
    "build": "npm run frontend-build && tsc && electron-builder",
    "frontend-build": "cd ../flexiopage-frontend && npm run build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "tsc": "tsc"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "electron-is-dev": "^2.0.0",
    "electron-log": "^4.4.8",
    "node-notifier": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "typescript": "^5.3.3",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.flexiopage.app",
    "productName": "Flexiopage",
    "files": [
      "src/main/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
