# FlexioPage — Production environment for VPS deployment.
# Copy to `.env` on the VPS, fill every required value, then:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d --build

# ─── Domains ──────────────────────────────────────────────────────────
# Public URLs the user (and the browser) will hit. You MUST point both
# DNS records (A or AAAA) to your VPS IP before launching nginx + SSL.
DOMAIN=flexiopage.com
API_DOMAIN=api.flexiopage.com

# Same values, but with https:// — read by Node and Next at runtime.
FRONTEND_URL=https://flexiopage.com
API_PUBLIC_URL=https://api.flexiopage.com

# Baked into the frontend JS at build time. MUST match API_PUBLIC_URL.
NEXT_PUBLIC_API_URL=https://api.flexiopage.com

# Root domain for storefront subdomains (e.g. macaftans.flexiopage.com).
# Also baked at build time. Requires wildcard DNS + wildcard SSL covering
# *.flexiopage.com. Leave unset to disable subdomain URLs (path-based fallback).
NEXT_PUBLIC_STOREFRONT_DOMAIN=flexiopage.com

# ─── Auth ─────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES=7d

# ─── Storage ──────────────────────────────────────────────────────────
# `local` keeps uploads on the VPS disk (Docker volume — persistent across
# container restarts and redeploys). Set to `s3` to push to S3/R2/etc.
STORAGE_DRIVER=local

# When STORAGE_DRIVER=s3, fill these:
# S3_BUCKET=flexiopage-media
# S3_REGION=auto
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── Stripe (optional, only for card payments) ────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── AI / Landing pages ───────────────────────────────────────────────
# FAL_KEY is the single API key for everything — copy/vision LLM (Claude
# via fal proxy) AND image generation (Nano Banana, FLUX, Ideogram).
# Get yours at https://fal.ai/dashboard/keys
FAL_KEY=<key_id>:<key_secret>

# ── Text generation (copy + vision/captioning) ──
# Claude Sonnet 4.5 is currently the best Arabic/Darija copywriter and
# delivers SOTA image captioning in one shot. Don't downgrade unless you
# have a strong reason — Arabic dialect handling collapses on smaller LLMs.
FAL_LLM_MODEL=anthropic/claude-sonnet-4.5
FAL_CAPTION_MODEL=anthropic/claude-sonnet-4.5

# ── Image generation (per slot kind) ──
# Nano Banana (Google Gemini 2.5 Flash Image) is the strongest for
# product photography with reference images — it preserves the actual
# product while restaging it. The pipeline auto-routes to
# `fal-ai/nano-banana/edit` whenever a reference image is provided.
FAL_HERO_MODEL=fal-ai/nano-banana
FAL_GALLERY_MODEL=fal-ai/nano-banana
FAL_AVATAR_MODEL=fal-ai/flux-realism
# Ideogram v3 stays for banners — it's the only model that reliably
# renders legible Arabic / Latin text inside the image itself.
FAL_BANNER_MODEL=fal-ai/ideogram/v3

# Toggle to disable AI image steps and ship copy-only landings.
LANDING_AI_IMAGES_ENABLED=true

# ─── Email (optional) ─────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=FlexioPage <noreply@flexiopage.com>

# ─── Mobile-money payments / CinetPay (optional) ──────────────────────
# CINETPAY_API_KEY=
# CINETPAY_SITE_ID=
# CINETPAY_NOTIFY_URL=https://api.flexiopage.com/api/webhooks/cinetpay

# ─── MogaDelivery webhook (optional) ──────────────────────────────────
# Generate: openssl rand -hex 32
# FLEXIOPAGE_WEBHOOK_SECRET=
# MOGADELIVERY_WEBHOOK_URL=https://api.admin-mogadelivery.com/api/webhooks/flexiopage
