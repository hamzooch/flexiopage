# API base URL (used for both client and server-side fetches)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Root domain for storefront subdomains, e.g. macaftans.flexiopage.com.
# When set, "View store" buttons + share links use the canonical
# subdomain URL. Unset (or localhost*) → path-based dev fallback.
# Requires wildcard DNS (*.flexiopage.com) + wildcard SSL on prod.
# NEXT_PUBLIC_STOREFRONT_DOMAIN=flexiopage.com

# Google OAuth — same Web Application Client ID configured on the backend
# (GOOGLE_CLIENT_ID). The frontend uses it to render the GoogleLogin
# button; the credential it produces is verified server-side. Leave empty
# to hide the "Continuer avec Google" button gracefully.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
